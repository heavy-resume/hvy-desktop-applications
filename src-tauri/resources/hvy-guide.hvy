   <!--hvy:xref-card {"css":"margin: 0.5rem 0; padding-left: 0.5rem;","xrefTitle":"Expandable","xrefDetail":"Show a preview or provide a stub that expands to deeper content","xrefTarget":"component-expandable"}-->

   <!--hvy:xref-card {"css":"margin: 0.5rem 0; padding-left: 0.5rem;","xrefTitle":"List","xrefDetail":"Provide a list of components (often references)","xrefTarget":"component-list"}-->

