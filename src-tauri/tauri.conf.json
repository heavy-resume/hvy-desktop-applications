{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "HVY Galaxy",
  "mainBinaryName": "HVY Galaxy",
  "version": "0.1.0-alpha.2",
  "identifier": "com.heavyresume.hvy-galaxy",
  "build": {
    "beforeDevCommand": "node node_modules/vite/bin/vite.js --host 127.0.0.1 --port 1420",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HVY Galaxy",
        "width": 1200,
        "height": 780,
        "minWidth": 920,
        "minHeight": 640,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "HVY Galaxy",
    "longDescription": "HVY Galaxy document editor.",
    "fileAssociations": [
      {
        "ext": ["hvy", "thvy", "phvy"],
        "name": "HVY Document",
        "description": "HVY document",
        "role": "Editor",
        "mimeType": "application/x-hvy",
        "rank": "Owner",
        "exportedType": {
          "identifier": "com.heavyresume.hvy-document",
          "conformsTo": ["public.data"]
        }
      }
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "minimumSystemVersion": "10.13"
    },
    "resources": {
      "../src/assets/hvy-galaxy.hvy": "resources/hvy-galaxy.hvy",
      "resources/hvy-guide.hvy": "resources/hvy-guide.hvy"
    }
  }
}
